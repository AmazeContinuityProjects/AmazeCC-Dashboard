ADMIN_PASSWORD="your_admin_password_here"
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabase client (same project as DATABASE_URL — for storage uploads)
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
# NOTE: Get the anon key from your Supabase dashboard > Settings > API
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

NEXT_PUBLIC_API_BASE=http://localhost:3005
ADMIN_VTOP_IDS=ADMIN_ID_1,ADMIN_ID_2
